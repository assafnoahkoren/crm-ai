{
  "name": "@crm-ai/server",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bunx prisma generate && bun build src/index.ts --outdir dist --target bun",
    "start": "bun dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@crm-ai/shared": "workspace:*",
    "@prisma/client": "^6",
    "@trpc/server": "^11",
    "better-auth": "^1.6.5",
    "cors": "^2",
    "pino": "^9",
    "pino-pretty": "^13",
    "zod": "^3"
  },
  "devDependencies": {
    "typescript": "^5",
    "eslint": "^9",
    "typescript-eslint": "^8",
    "@types/bun": "latest",
    "@types/cors": "^2",
    "prisma": "^6"
  }
}
