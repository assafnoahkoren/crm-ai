{
  "name": "crm-ai",
  "private": true,
  "packageManager": "bun@1.2.21",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,css,md}\"",
    "db:push": "cd packages/server && bunx prisma db push",
    "db:generate": "cd packages/server && bunx prisma generate",
    "db:seed": "cd packages/server && bun run src/db/seed.ts",
    "db:studio": "cd packages/server && bunx prisma studio",
    "dev:server": "cd packages/server && bun run dev",
    "dev:client": "cd packages/client && bun run dev",
    "prepare": "husky"
  },
  "devDependencies": {
    "turbo": "^2",
    "prettier": "^3",
    "husky": "^9",
    "lint-staged": "^15"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
